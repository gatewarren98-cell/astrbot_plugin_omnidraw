{
  "permission_config": {
    "type": "object",
    "description": "🛡️ 权限控制",
    "hint": "管理谁可以使用本插件的生图和视频功能",
    "items": {
      "allowed_users": {
        "type": "string",
        "description": "允许使用的QQ号",
        "hint": "多个用英文逗号隔开。留空则默认全员可用。",
        "default": ""
      }
    },
    "default": {}
  },
  "persona_config": {
    "type": "object",
    "description": "🎭 人设定制",
    "hint": "定义 AI 助理在使用 /自拍 时的专属固定形象",
    "items": {
      "persona_name": { "description": "助理名称", "hint": "如: 默认助理", "type": "string", "default": "默认助理" },
      "persona_base_prompt": { "description": "外貌特征", "hint": "固定在提示词前方的英文正向特征", "type": "text", "default": "masterpiece, best quality, 1girl" },
      "persona_ref_image": { "description": "形象参考图", "hint": "直接点击上传人脸/形象参考图", "type": "file", "default": [] }
    },
    "default": {}
  },
  "optimizer_config": {
    "type": "object",
    "description": "🧠 提示词副脑 (Prompt Optimizer)",
    "hint": "拦截简单指令并自动扩写为高维度英文提示词",
    "items": {
      "enable_optimizer": { "type": "bool", "description": "副脑总开关", "hint": "大模型自拍时是否调用副脑？", "default": true },
      "chain_optimizer": { "description": "执行链路", "hint": "调用哪个节点来扩写提示词", "type": "string", "default": "node_1" },
      "optimizer_model": { "description": "指定模型", "hint": "推荐极速模型，如 gpt-4o-mini", "type": "string", "default": "gpt-4o-mini" },
      "optimizer_timeout": { "description": "超时时间 (秒)", "hint": "建议 8~15 秒", "type": "string", "default": "15" },
      "max_batch_count": { "type": "int", "description": "批量生成数量上限", "hint": "0 表示无上限。防止大模型胡乱调用耗尽余额。", "default": 0 }
    },
    "default": {}
  },
  "router_config": {
    "type": "object",
    "description": "🔗 路由调度",
    "hint": "将不同的指令绑定到具体的 API 节点执行",
    "items": {
      "chain_text2img": { "description": "常规画图链路", "hint": "执行 /画 绑定的节点ID", "type": "string", "default": "node_1" },
      "chain_selfie": { "description": "自拍专用链路", "hint": "执行 /自拍 绑定的节点ID", "type": "string", "default": "node_1" },
      "chain_video": { "description": "视频生成链路", "hint": "执行 /视频 绑定的视频节点ID", "type": "string", "default": "video_node_1" }
    },
    "default": {}
  },
  "providers": {
    "description": "🎨 API 生图节点配置",
    "hint": "支持添加多个 OpenAI 兼容协议的生图节点",
    "type": "template_list",
    "items": {
      "type": "object",
      "keys": {
        "id": { "description": "节点ID", "type": "string", "default": "node_1" },
        "api_type": { "description": "接口模式", "type": "string", "options": ["openai_image", "openai_chat"], "default": "openai_image" },
        "base_url": { "description": "接口地址", "type": "string", "default": "https://api.openai.com/v1" },
        "api_keys": { "description": "密钥池 (一行一个)", "type": "text", "default": "" },
        "model": { "description": "模型名称 (多个用逗号隔开)", "type": "string", "default": "banana" },
        "timeout": { "description": "超时时间 (秒)", "type": "string", "default": "60" }
      }
    },
    "templates": {
      "openai_node": {
        "name": "➕ 添加生图节点",
        "items": {
          "id": { "description": "节点ID", "type": "string", "default": "node_1" },
          "api_type": { "description": "接口模式", "type": "string", "options": ["openai_image", "openai_chat"], "default": "openai_image" },
          "base_url": { "description": "接口地址", "type": "string", "default": "https://api.openai.com/v1" },
          "api_keys": { "description": "密钥池", "type": "text", "default": "sk-xxxxxx" },
          "model": { "description": "模型名称", "type": "string", "default": "banana" },
          "timeout": { "description": "超时时间", "type": "string", "default": "60" }
        }
      }
    },
    "default": []
  },
  "video_providers": {
    "description": "🎬 API 视频节点配置",
    "hint": "支持添加挂机渲染的长耗时视频节点",
    "type": "template_list",
    "items": {
      "type": "object",
      "keys": {
        "id": { "description": "节点ID", "type": "string", "default": "video_node_1" },
        "api_type": { "description": "接口模式", "type": "string", "options": ["openai_video"], "default": "openai_video" },
        "base_url": { "description": "接口地址", "type": "string", "default": "https://api.example.com" },
        "api_keys": { "description": "密钥池 (一行一个)", "type": "text", "default": "" },
        "model": { "description": "视频模型名称 (多个用逗号隔开)", "type": "string", "default": "sora" },
        "timeout": { "description": "长连接超时 (秒)", "type": "string", "default": "300" }
      }
    },
    "templates": {
      "openai_video_node": {
        "name": "➕ 添加视频节点",
        "items": {
          "id": { "description": "节点ID", "type": "string", "default": "video_node_1" },
          "api_type": { "description": "接口模式", "type": "string", "options": ["openai_video"], "default": "openai_video" },
          "base_url": { "description": "接口地址", "type": "string", "default": "https://api.example.com" },
          "api_keys": { "description": "密钥池", "type": "text", "default": "sk-xxxxxx" },
          "model": { "description": "视频模型名称", "type": "string", "default": "sora" },
          "timeout": { "description": "长连接超时时间", "type": "string", "default": "300" }
        }
      }
    },
    "default": []
  }
}
